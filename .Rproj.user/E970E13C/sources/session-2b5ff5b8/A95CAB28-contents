## 4. Cross-Validation (10-Fold)

We use 10-fold cross-validation to get a baseline RMSE on the log scale to compare future models against.

```{r cv-full}
set.seed(42)

n     <- nrow(model_df)
folds <- sample(rep(1:10, length.out = n))
rmse_folds <- numeric(10)

for (k in 1:10) {
  train <- model_df[folds != k, ]
  test  <- model_df[folds == k, ]

  fit <- lm(
    log_Global_Sales ~ Critic_Score + User_Score_100 + Year_of_Release + Genre + Rating,
    data = train
  )

  preds <- predict(fit, newdata = test)
  rmse_folds[k] <- sqrt(mean((test$log_Global_Sales - preds)^2))
}

cat("10-Fold CV RMSE (log scale):", round(mean(rmse_folds), 4), "\n")
cat("SD across folds:            ", round(sd(rmse_folds),   4), "\n")
```

> This is our **baseline RMSE** , all subsequent models will be compared against this value.


## 5. Model Improvement Attempts

### 5a. Remove Non Significant Predictors (AIC-based Stepwise)

```{r stepwise, results='hide'}
step_model <- step(full_model, direction = "both", trace = 0)
```

```{r stepwise-summary}
summary(step_model)
cat("AIC — Full Model: ", round(AIC(full_model),  2), "\n")
cat("AIC — Step Model: ", round(AIC(step_model),  2), "\n")
```

```{r cv-step}
set.seed(42)
rmse_step <- numeric(10)

for (k in 1:10) {
  train <- model_df[folds != k, ]
  test  <- model_df[folds == k, ]

  fit <- lm(formula(step_model), data = train)
  preds <- predict(fit, newdata = test)
  rmse_step[k] <- sqrt(mean((test$log_Global_Sales - preds)^2))
}

cat("10-Fold CV RMSE — Step Model:", round(mean(rmse_step), 4), "\n")
```

---

### 5b. Interaction: Critic Score × Genre

This tests whether the relationship between critic scores and sales varies by genre, a key research question for this project.

```{r model-int-genre}
model_int_genre <- lm(
  log_Global_Sales ~ Critic_Score * Genre + User_Score_100 + Year_of_Release + Rating,
  data = model_df
)

summary(model_int_genre)
cat("\nAIC — Interaction (Genre): ", round(AIC(model_int_genre), 2), "\n")
```

```{r cv-int-genre}
set.seed(42)
rmse_int_genre <- numeric(10)

for (k in 1:10) {
  train <- model_df[folds != k, ]
  test  <- model_df[folds == k, ]

  fit <- lm(
    log_Global_Sales ~ Critic_Score * Genre + User_Score_100 + Year_of_Release + Rating,
    data = train
  )
  preds <- predict(fit, newdata = test)
  rmse_int_genre[k] <- sqrt(mean((test$log_Global_Sales - preds)^2))
}

cat("10-Fold CV RMSE Critic × Genre:", round(mean(rmse_int_genre), 4), "\n")
```

---

### 5c. Interaction: Critic Score × User Score

Tests whether games that score well with both critics AND users sell significantly more than what each score alone would predict.

```{r model-int-scores}
model_int_scores <- lm(
  log_Global_Sales ~ Critic_Score * User_Score_100 + Year_of_Release + Genre + Rating,
  data = model_df
)

summary(model_int_scores)
cat("\nAIC — Interaction (Scores): ", round(AIC(model_int_scores), 2), "\n")
```

```{r cv-int-scores}
set.seed(42)
rmse_int_scores <- numeric(10)

for (k in 1:10) {
  train <- model_df[folds != k, ]
  test  <- model_df[folds == k, ]

  fit <- lm(
    log_Global_Sales ~ Critic_Score * User_Score_100 + Year_of_Release + Genre + Rating,
    data = train
  )
  preds <- predict(fit, newdata = test)
  rmse_int_scores[k] <- sqrt(mean((test$log_Global_Sales - preds)^2))
}

cat("10-Fold CV RMSE — Critic × User Score:", round(mean(rmse_int_scores), 4), "\n")
```

---

### 5d. Polynomial: Year of Release

The video game industry grew and then plateaued, a quadratic term for year may capture that curve better than a linear one.

```{r model-poly-year}
model_poly_year <- lm(
  log_Global_Sales ~ Critic_Score + User_Score_100 +
    poly(Year_of_Release, 2) + Genre + Rating,
  data = model_df
)

summary(model_poly_year)
cat("\nAIC — Poly Year: ", round(AIC(model_poly_year), 2), "\n")
```

```{r cv-poly-year}
set.seed(42)
rmse_poly_year <- numeric(10)

for (k in 1:10) {
  train <- model_df[folds != k, ]
  test  <- model_df[folds == k, ]

  fit <- lm(
    log_Global_Sales ~ Critic_Score + User_Score_100 +
      poly(Year_of_Release, 2) + Genre + Rating,
    data = train
  )
  preds <- predict(fit, newdata = test)
  rmse_poly_year[k] <- sqrt(mean((test$log_Global_Sales - preds)^2))
}

cat("10-Fold CV RMSE — Poly Year:", round(mean(rmse_poly_year), 4), "\n")
```

---

### 5e. Combined Best Model

Based on the above results, we combine the most promising improvements into one model.

```{r model-best}
model_best <- lm(
  log_Global_Sales ~ Critic_Score * Genre + User_Score_100 +
    poly(Year_of_Release, 2) + Rating,
  data = model_df
)

summary(model_best)
cat("\nAIC — Best Model: ", round(AIC(model_best), 2), "\n")
```

```{r cv-best}
set.seed(42)
rmse_best <- numeric(10)

for (k in 1:10) {
  train <- model_df[folds != k, ]
  test  <- model_df[folds == k, ]

  fit <- lm(
    log_Global_Sales ~ Critic_Score * Genre + User_Score_100 +
      poly(Year_of_Release, 2) + Rating,
    data = train
  )
  preds <- predict(fit, newdata = test)
  rmse_best[k] <- sqrt(mean((test$log_Global_Sales - preds)^2))
}

cat("10-Fold CV RMSE — Best Model:", round(mean(rmse_best), 4), "\n")
```

